# =============================================================================
# Cinemate — Root Docker Compose Environment
# Copy this file to .env and fill in every value marked <FILL_IN>.
# The .env file is loaded automatically by Docker Compose.
# =============================================================================

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_DATABASE=Cinemate
MYSQL_ROOT_PASSWORD=123456

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# No auth in the current Compose setup — add credentials here if you add them.
MONGO_INITDB_DATABASE=Cinemate2

# ─── Spring Boot Backend ──────────────────────────────────────────────────────
SPRING_APPLICATION_NAME=Cinemate
DB_URL=jdbc:mysql://mysql:3306/Cinemate?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=123456
# This value isn't actually read by the backend container (it loads JPA_DDL_AUTO from
# backend/.env.prod instead — see that file for why it's "update" and not "validate").
# Kept here in sync anyway so the two templates don't silently disagree (§11.2).
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
MONGODB_URI=mongodb://mongodb:27017/Cinemate2

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=<FILL_IN: 64+ character random secret>

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# See docs/environment.md §Google OAuth2 for setup steps.
GOOGLE_CLIENT_ID=<FILL_IN>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<FILL_IN>

# BASE_URL: the externally reachable URL of the backend service.
# In local Docker Compose this is http://localhost:8080.
# In production set it to your backend's public domain.
BASE_URL=http://localhost:8080

# ─── Frontend / CORS ──────────────────────────────────────────────────────────
# FRONTEND_URL: the externally reachable URL of the frontend.
# The backend redirects here after a successful Google login.
FRONTEND_URL=http://localhost:5173

# CORS_ALLOWED_ORIGINS: comma-separated list of origins the backend accepts.
# Add your production domain when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── SendGrid ─────────────────────────────────────────────────────────────────
# See docs/environment.md §SendGrid for setup steps.
SENDGRID_API_KEY=<FILL_IN: SG.xxxxx>
SENDGRID_FROM_EMAIL=<FILL_IN: verified sender address, e.g. no-reply@cinemate.example.com>

# ─── Hate-Speech API ──────────────────────────────────────────────────────────
# URL of the hate-api /analyze endpoint as seen from inside the Docker network.
HATE_MODEL_URL=http://hate-api:8000/api/hate/v1/analyze
# Shared secret for backend → hate-api internal calls.
# Generate with: openssl rand -hex 32
HATE_API_KEY=<FILL_IN: random secret shared between backend and hate-api>

# ─── Watch-Party Microservice ─────────────────────────────────────────────────
# Internal URLs — these are Docker service names and stay the same in Compose.
WATCHPARTY_SERVICE_URL=http://watch-party:8081
WATCHPARTY_WS_URL=ws://watch-party:8081/ws
# Generate with: openssl rand -hex 32
WATCHPARTY_KEY=<FILL_IN: random secret shared between backend and watch-party>

# ─── Backend Response Cache (Redis) ───────────────────────────────────────────
# Dedicated cache instance (ARC-06) — deliberately NOT the same Redis instance
# watch-party uses above. See the `redis` vs `redis-cache` service comments in
# compose.yaml for why they're kept separate (conflicting eviction/durability needs).
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379

# ─── Spring Profiles ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
