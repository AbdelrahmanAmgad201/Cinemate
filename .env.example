# =============================================================================
# Cinemate — Root Docker Compose Environment
# Copy this file to .env and fill in every value marked <FILL_IN>.
# The .env file is loaded automatically by Docker Compose.
# =============================================================================

# ─── PostgreSQL (single datastore) ────────────────────────────────────────────
POSTGRES_DB=Cinemate
POSTGRES_USER=cinemate
POSTGRES_PASSWORD=123456

# ─── Spring Boot Backend ──────────────────────────────────────────────────────
SPRING_APPLICATION_NAME=Cinemate
# DB_URL/USERNAME/PASSWORD are injected into the backend container by compose.yaml
# from the POSTGRES_* values above; the schema is managed by Flyway migrations.
JPA_SHOW_SQL=false

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Access tokens are signed with the PRIVATE key and verified with the PUBLIC key.
# The public key is also what the API gateway needs to verify tokens at the edge.
# Generate a base64-DER keypair:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -pubout -in priv.pem -out pub.pem
#   JWT_PRIVATE_KEY=$(grep -v '^-' priv.pem | tr -d '\n')
#   JWT_PUBLIC_KEY=$(grep -v '^-' pub.pem | tr -d '\n')
JWT_PRIVATE_KEY=<FILL_IN: base64 PKCS#8 private key>
JWT_PUBLIC_KEY=<FILL_IN: base64 X.509 public key>
# Optional lifetimes (defaults: 15 min access / 7 days refresh):
# JWT_ACCESS_TOKEN_EXP_MS=900000
# JWT_REFRESH_TOKEN_EXP_MS=604800000

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# See docs/environment.md §Google OAuth2 for setup steps.
GOOGLE_CLIENT_ID=<FILL_IN>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<FILL_IN>

# BASE_URL: the single externally-reachable URL — the GATEWAY. Everything (SPA, API,
# WebSocket) is served from here. In local Docker Compose it's http://localhost:8080;
# in production set it to your public domain.
BASE_URL=http://localhost:8080

# ─── Origins ──────────────────────────────────────────────────────────────────
# FRONTEND_URL: the gateway origin the backend redirects to after a Google login.
FRONTEND_URL=http://localhost:8080

# CORS_ALLOWED_ORIGINS: the browser origin (the gateway). The backend no longer does
# CORS (single origin); this is consumed only by watch-party's WebSocket origin check.
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ─── SendGrid ─────────────────────────────────────────────────────────────────
# See docs/environment.md §SendGrid for setup steps.
SENDGRID_API_KEY=<FILL_IN: SG.xxxxx>
SENDGRID_FROM_EMAIL=<FILL_IN: verified sender address, e.g. no-reply@cinemate.example.com>

# ─── Content Moderation (Kafka pipeline) ──────────────────────────────────────
# Backend and moderation-worker talk over the internal Kafka broker (wired in
# compose.yaml). The worker's toxicity thresholds default in compose.yaml — override
# here only if needed. The pinned model is baked into the worker image at build time.
# TOXIC_THRESHOLD=0.5
# SEVERE_TOXIC_THRESHOLD=0.5
# HF_MODEL_REPO=minuva/MiniLMv2-toxic-jigaw-lite-onnx
# HF_MODEL_REVISION=82158a0b785a545700601d6a72634528f2b917c2

# ─── Watch-Party Microservice ─────────────────────────────────────────────────
# Internal URLs — these are Docker service names and stay the same in Compose.
WATCHPARTY_SERVICE_URL=http://watch-party:8081
WATCHPARTY_WS_URL=ws://watch-party:8081/ws
# Generate with: openssl rand -hex 32
WATCHPARTY_KEY=<FILL_IN: random secret shared between backend and watch-party>

# ─── Redis (gateway rate-limiter only) ────────────────────────────────────────
# The backend no longer uses Redis; the only instance left (`redis-ratelimit` in
# compose.yaml) backs the gateway's Bucket4j token buckets and needs no config here.

# ─── Spring Profiles ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
