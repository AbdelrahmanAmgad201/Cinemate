# =============================================================================
# Cinemate Frontend — Vite Environment Variables
# Copy this file to .env.local for local dev, or update .env.production for prod builds.
# All variables MUST start with VITE_ to be exposed to the browser bundle.
# These values are baked into the static files at build time — not runtime.
# =============================================================================

# Base URL of the backend REST API (no trailing slash).
VITE_API_BASE_URL=http://localhost:8080

# Base URL of the watch-party WebSocket microservice (no trailing slash).
VITE_API_WATCH_PARTY_BASE_URL=http://localhost:8081
