# =============================================================================
# Cinemate Backend — Application Environment Variables
# Copy this file to .env.prod and fill in every value marked <FILL_IN>.
# This file is loaded by Docker Compose via env_file: ./backend/.env.prod
# =============================================================================

SPRING_APPLICATION_NAME=Cinemate

# ─── PostgreSQL (single datastore) ────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/Cinemate
DB_USERNAME=cinemate
DB_PASSWORD=<FILL_IN: same as POSTGRES_PASSWORD>

# Schema is owned by Flyway migrations (backend/src/main/resources/db/migration).
# Hibernate only validates entities against it — it never alters the schema.
JPA_SHOW_SQL=false

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# base64-DER keypair. The public key is what a gateway needs to verify tokens.
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -pubout -in priv.pem -out pub.pem
#   JWT_PRIVATE_KEY=$(grep -v '^-' priv.pem | tr -d '\n')
#   JWT_PUBLIC_KEY=$(grep -v '^-' pub.pem | tr -d '\n')
JWT_PRIVATE_KEY=<FILL_IN: base64 PKCS#8 private key>
JWT_PUBLIC_KEY=<FILL_IN: base64 X.509 public key>

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<FILL_IN>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<FILL_IN>

# Public URL of this backend service (used in OAuth2 redirect URI).
# Local Docker: http://localhost:8080
# Production:   https://api.cinemate.example.com
BASE_URL=http://localhost:8080

# ─── Frontend ─────────────────────────────────────────────────────────────────
# The gateway origin (single entry point) — used for the post-OAuth redirect.
FRONTEND_URL=http://localhost:8080

# CORS is handled at the gateway now; this remains only for watch-party's WS check.
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=<FILL_IN: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx>
SENDGRID_FROM_EMAIL=<FILL_IN: e.g. no-reply@cinemate.example.com>

# ─── Content-Moderation Pipeline (Kafka) ─────────────────────────────────────
# The backend publishes moderation requests (transactional outbox → Kafka) and
# consumes verdicts. Internal-only broker on app-net; toxicity thresholds live on
# the moderation-worker (TOXIC_THRESHOLD / SEVERE_TOXIC_THRESHOLD).
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── Redis ────────────────────────────────────────────────────────────────────
# The backend no longer uses Redis at all — the response cache and the refresh/OAuth
# token stores moved into Postgres. The only Redis left in the system backs the
# gateway's rate-limiter (see gateway config + compose.yaml `redis-ratelimit`).

# ─── Spring Profile ───────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
