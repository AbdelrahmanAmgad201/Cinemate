# =============================================================================
# Cinemate Backend — Application Environment Variables
# Copy this file to .env.prod and fill in every value marked <FILL_IN>.
# This file is loaded by Docker Compose via env_file: ./backend/.env.prod
# =============================================================================

SPRING_APPLICATION_NAME=Cinemate

# ─── MySQL ────────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://mysql:3306/Cinemate?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=<FILL_IN: same as MYSQL_ROOT_PASSWORD>

# validate = check schema matches entities but don't alter it (safe for prod)
# update  = auto-alter schema (safe for local dev — creates tables on first run)
# create  = drop and recreate (NEVER use in prod)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/Cinemate2

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 64 characters for HS512.
# Generate: openssl rand -hex 64
JWT_SECRET=<FILL_IN>

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<FILL_IN>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<FILL_IN>

# Public URL of this backend service (used in OAuth2 redirect URI).
# Local Docker: http://localhost:8080
# Production:   https://api.cinemate.example.com
BASE_URL=http://localhost:8080

# ─── Frontend / CORS ──────────────────────────────────────────────────────────
# Public URL of the frontend — used for the post-OAuth redirect.
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins (no trailing slashes).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=<FILL_IN: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx>
SENDGRID_FROM_EMAIL=<FILL_IN: e.g. no-reply@cinemate.example.com>

# ─── Hate-Speech Microservice ─────────────────────────────────────────────────
HATE_MODEL_URL=http://hate-api:8000/api/hate/v1/analyze

# ─── Watch-Party Microservice ─────────────────────────────────────────────────
WATCHPARTY_SERVICE_URL=http://watch-party:8081
WATCHPARTY_WS_URL=ws://watch-party:8081/ws
# Shared secret for backend → watch-party internal calls.
# Generate: openssl rand -hex 32
WATCHPARTY_KEY=<FILL_IN>

# ─── Spring Profile ───────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
