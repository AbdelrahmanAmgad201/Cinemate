config.stopBubbling = true

# Spring's @Lazy is used on a constructor-injected field in SecurityConfig
# (oAuthSuccessHandler) to defer its initialization. Lombok's generated
# constructors don't copy field annotations onto their parameters by default,
# and Spring only honors @Lazy when it's on the constructor parameter itself
# — so without this, the annotation is silently inert.
lombok.copyableAnnotations += org.springframework.context.annotation.Lazy
